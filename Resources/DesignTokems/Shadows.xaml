<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  =====================================================  -->
    <!--  SMALL SHADOW  -->
    <!--  =====================================================  -->

    <DropShadowEffect
        x:Key="Shadow.Small"
        BlurRadius="8"
        Opacity="0.18"
        ShadowDepth="2"
        Color="#000000" />

    <!--  =====================================================  -->
    <!--  MEDIUM SHADOW  -->
    <!--  =====================================================  -->

    <DropShadowEffect
        x:Key="Shadow.Medium"
        BlurRadius="14"
        Opacity="0.24"
        ShadowDepth="3"
        Color="#000000" />

    <!--  =====================================================  -->
    <!--  LARGE SHADOW  -->
    <!--  =====================================================  -->

    <DropShadowEffect
        x:Key="Shadow.Large"
        BlurRadius="24"
        Opacity="0.30"
        ShadowDepth="5"
        Color="#000000" />

</ResourceDictionary>