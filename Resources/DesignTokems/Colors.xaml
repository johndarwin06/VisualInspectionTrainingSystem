    <!--  =====================================================  -->

    <Color x:Key="Color.Blue.900">#0A3558</Color>
    <Color x:Key="Color.Blue.800">#0F4C81</Color>
    <Color x:Key="Color.Blue.700">#1565C0</Color>
    <Color x:Key="Color.Blue.500">#2196F3</Color>
    <Color x:Key="Color.Blue.300">#64B5F6</Color>

