<Window x:Class="VisualInspectionTrainingSystem.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:VisualInspectionTrainingSystem.Helpers"
        Title="Visual Inspection Training System"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F5F7FA">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <Grid Grid.Column="0"
              Background="#0F4C81">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <!-- Logo -->
                <Image Width="220"
                       Height="220"
                       Source="/Assets/Logos/logo.png"
                       Stretch="Uniform"/>

                <TextBlock
                    Margin="0,20,0,0"
                    Text="VISUAL INSPECTION"
                    Foreground="White"
                    FontSize="30"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"/>

                <TextBlock
                    Text="TRAINING SYSTEM"
                    Foreground="White"
                    FontSize="22"
                    HorizontalAlignment="Center"/>

                <TextBlock
                    Margin="0,30,0,0"
                    Text="Product Appearance Training"
                    Foreground="White"
                    FontSize="15"
                    HorizontalAlignment="Center"/>

            </StackPanel>

        </Grid>

        <!-- Right Panel -->
        <Border Grid.Column="1"
                Background="White"
                Padding="40">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="35"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="20"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="30"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="20"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- Title -->

                <TextBlock
                    Text="LOGIN"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#263238"/>

                <!-- Employee -->

                <StackPanel Grid.Row="2">

                    <TextBlock
                        Text="Employee Number"
                        FontWeight="SemiBold"
                        Margin="0,0,0,5"/>

                    <TextBox
                        Height="40"
                        FontSize="15"
                        Padding="10,5"
                        Text="{Binding EmployeeNo,
                                       UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>

                <!-- Password -->

                <StackPanel Grid.Row="4">

                    <TextBlock
                        Text="Password"
                        FontWeight="SemiBold"
                        Margin="0,0,0,5"/>

                    <PasswordBox
                        Height="40"
                        FontSize="15"
                        Padding="10,5"
                        helpers:PasswordBoxHelper.BindPassword="True"
                        helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}" />

                </StackPanel>

                <!-- Buttons -->

                <Grid Grid.Row="6">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition/>

                        <ColumnDefinition Width="10"/>

                        <ColumnDefinition/>

                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Height="42"
                        Content="LOGIN"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#0F4C81"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding LoginCommand}"/>

                    <Button
                        Grid.Column="2"
                        Height="42"
                        Content="EXIT"
                        Cursor="Hand"
                        Command="{Binding ExitCommand}"/>

                </Grid>

                <!-- Status -->

                <TextBlock
                    Grid.Row="8"
                    Foreground="Red"
                    FontWeight="SemiBold"
                    Text="{Binding StatusMessage}"/>

                <!-- Footer -->

                <DockPanel Grid.Row="10">

                    <TextBlock
                        Text="Samsung Electro-Mechanics Philippines"/>

                    <TextBlock
                        DockPanel.Dock="Right"
                        Text="{Binding Version}"/>

                </DockPanel>

            </Grid>

        </Border>

    </Grid>

</Window>