<Window
    x:Class="VisualInspectionTrainingSystem.Views.Reports.ReportsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Reports"
    Width="1400"
    Height="820"
    MinWidth="1120"
    MinHeight="680"
    Background="#0B1220"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="102" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="4,0,0,4" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#1F4E78" />
            <Setter Property="BorderBrush" Value="#4C8BC3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563A8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PeriodButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#4B5563" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#263449" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#93A4BA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="142" />
            <Setter Property="Margin" Value="6,0,14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock
                    Foreground="#F8FAFC"
                    FontSize="28"
                    FontWeight="Bold"
                    Text="Reports" />
                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                    <TextBlock
                        Foreground="#60A5FA"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="{Binding ActivePeriodText}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="#94A3B8"
                        FontSize="13"
                        Text="{Binding DateRangeText}" />
                </StackPanel>
            </StackPanel>

            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                <Button
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Style="{StaticResource ActionButtonStyle}" />
                <Button
                    Command="{Binding ExportCsvCommand}"
                    Content="Export CSV"
                    Style="{StaticResource ActionButtonStyle}" />
                <Button
                    Command="{Binding ExportExcelCommand}"
                    Content="Export Excel"
                    Style="{StaticResource ActionButtonStyle}" />
                <Button
                    Command="{Binding ExportPdfCommand}"
                    Content="Export PDF"
                    Style="{StaticResource ActionButtonStyle}" />
            </WrapPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0,0,0,10"
            Padding="12,9"
            Background="#111827"
            BorderBrush="#263449"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#CBD5E1"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Custom range" />
                    <TextBlock
                        Margin="18,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#94A3B8"
                        Text="Start" />
                    <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#94A3B8"
                        Text="End" />
                    <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                    <TextBlock
                        Margin="2,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#64748B"
                        FontSize="11"
                        Text="Refresh applies these inclusive dates." />
                </WrapPanel>

                <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button
                        Command="{Binding TodayCommand}"
                        Content="Today"
                        Style="{StaticResource PeriodButtonStyle}" />
                    <Button
                        Command="{Binding ThisWeekCommand}"
                        Content="This Week"
                        Style="{StaticResource PeriodButtonStyle}" />
                    <Button
                        Command="{Binding LastSevenDaysCommand}"
                        Content="Last 7 Days"
                        Style="{StaticResource PeriodButtonStyle}" />
                    <Button
                        Command="{Binding ThisMonthCommand}"
                        Content="This Month"
                        Style="{StaticResource PeriodButtonStyle}" />
                    <Button
                        Command="{Binding AllDatesCommand}"
                        Content="All Dates"
                        Style="{StaticResource PeriodButtonStyle}" />
                </WrapPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Margin="-4,0,-4,10" Columns="8" Rows="1">
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="TOTAL SESSIONS" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{Binding SessionCountText}" />
                    <TextBlock
                        Foreground="#94A3B8"
                        FontSize="10"
                        Text="{Binding CompletedOpenSessionsText}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="TRAINEES" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{Binding TraineeCountText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="QUESTIONS" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{Binding TotalQuestionsText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="REVIEWED" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{Binding ReviewedAnswersText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="PENDING" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{Binding PendingAnswersText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="REVIEW RESULT" />
                    <TextBlock
                        Style="{StaticResource CardValueStyle}"
                        FontSize="13"
                        Text="{Binding CorrectWrongText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="REVIEWED ACCURACY" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{Binding AverageAccuracyText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardLabelStyle}" Text="FIRST / LAST SESSION" />
                    <TextBlock
                        Style="{StaticResource CardValueStyle}"
                        FontSize="11"
                        Text="{Binding FirstLastSessionText}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border
            Grid.Row="3"
            Background="#111827"
            BorderBrush="#263449"
            BorderThickness="1"
            CornerRadius="8">
            <DataGrid
                ItemsSource="{Binding Sessions}"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="True"
                CanUserResizeColumns="True"
                ColumnHeaderHeight="34"
                EnableRowVirtualization="True"
                Foreground="#E2E8F0"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#253247"
                IsReadOnly="True"
                RowBackground="#111827"
                AlternatingRowBackground="#0F1929"
                RowHeaderWidth="0"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                VerticalGridLinesBrush="#253247">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#172235" />
                        <Setter Property="Foreground" Value="#CBD5E1" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="7,0" />
                        <Setter Property="BorderBrush" Value="#263449" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="#E2E8F0" />
                        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}" />
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding SessionID}" Header="Session" Width="72" />
                    <DataGridTextColumn Binding="{Binding EmployeeNo}" Header="Employee" Width="92" />
                    <DataGridTextColumn Binding="{Binding FullName}" Header="Full Name" Width="150" />
                    <DataGridTextColumn Binding="{Binding Department}" Header="Department" Width="115" />
                    <DataGridTextColumn Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Header="Start" Width="126" />
                    <DataGridTextColumn Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=N/A}" Header="End" Width="126" />
                    <DataGridTextColumn Binding="{Binding Status}" Header="Status" Width="80" />
                    <DataGridTextColumn Binding="{Binding TotalQuestions}" Header="Questions" Width="74" />
                    <DataGridTextColumn Binding="{Binding CorrectAnswers}" Header="Correct" Width="66" />
                    <DataGridTextColumn Binding="{Binding WrongAnswers}" Header="Wrong" Width="62" />
                    <DataGridTextColumn Binding="{Binding PendingAnswers}" Header="Pending" Width="66" />
                    <DataGridTextColumn Binding="{Binding ReviewedAnswers}" Header="Reviewed" Width="72" />
                    <DataGridTextColumn Binding="{Binding ReviewedAccuracyText}" Header="Accuracy" Width="78" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="4" Margin="2,9,2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    Foreground="#CBD5E1"
                    FontSize="12"
                    Text="{Binding StatusMessage}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,2,0,0"
                    Foreground="#F59E0B"
                    FontSize="11"
                    Text="{Binding EmptyStateText}" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock
                    HorizontalAlignment="Right"
                    Foreground="#60A5FA"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="{Binding BusyStatusText}" />
                <TextBlock
                    Margin="20,2,0,0"
                    HorizontalAlignment="Right"
                    Foreground="#94A3B8"
                    FontSize="11"
                    Text="{Binding DisplayLimitText}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
