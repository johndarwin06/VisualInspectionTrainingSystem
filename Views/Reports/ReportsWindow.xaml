<Window
    x:Class="VisualInspectionTrainingSystem.Views.Reports.ReportsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Reports"
    Width="1320"
    Height="780"
    MinWidth="1120"
    MinHeight="680"
    Background="#0F1720"
    FontFamily="Segoe UI"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="82" />
            <RowDefinition Height="14" />
            <RowDefinition Height="82" />
            <RowDefinition Height="14" />
            <RowDefinition Height="152" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="58" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="22,14"
            Background="#17212B"
            BorderBrush="#2D4050"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Training Reports" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="14"
                        Foreground="#9FB2C3"
                        Text="{Binding DateRangeText}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Height="46"
                    VerticalAlignment="Center"
                    Background="#2563EB"
                    BorderBrush="#60A5FA"
                    BorderThickness="1"
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />

                <Button
                    Grid.Column="3"
                    Height="46"
                    VerticalAlignment="Center"
                    Background="#166534"
                    BorderBrush="#22C55E"
                    BorderThickness="1"
                    Command="{Binding ExportCsvCommand}"
                    Content="Export CSV"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="112" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="#9FB2C3"
                    Text="Start Date" />

                <DatePicker
                    Grid.Column="1"
                    Height="36"
                    VerticalAlignment="Center"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    Foreground="#111827"
                    SelectedDate="{Binding StartDate, Mode=TwoWay}" />

                <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="#9FB2C3"
                    Text="End Date" />

                <DatePicker
                    Grid.Column="4"
                    Height="36"
                    VerticalAlignment="Center"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    Foreground="#111827"
                    SelectedDate="{Binding EndDate, Mode=TwoWay}" />

                <Button
                    Grid.Column="6"
                    Height="38"
                    VerticalAlignment="Center"
                    Background="#1F2937"
                    BorderBrush="#4B5563"
                    BorderThickness="1"
                    Command="{Binding TodayCommand}"
                    Content="Today"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC" />

                <Button
                    Grid.Column="8"
                    Height="38"
                    VerticalAlignment="Center"
                    Background="#1F2937"
                    BorderBrush="#4B5563"
                    BorderThickness="1"
                    Command="{Binding LastSevenDaysCommand}"
                    Content="7 Days"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC" />

                <Button
                    Grid.Column="10"
                    Height="38"
                    VerticalAlignment="Center"
                    Background="#1F2937"
                    BorderBrush="#4B5563"
                    BorderThickness="1"
                    Command="{Binding ThisMonthCommand}"
                    Content="Month"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC" />

                <Button
                    Grid.Column="12"
                    Height="38"
                    VerticalAlignment="Center"
                    Background="#374151"
                    BorderBrush="#6B7280"
                    BorderThickness="1"
                    Command="{Binding AllDatesCommand}"
                    Content="All"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="SESSIONS" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Text="{Binding SessionCountText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="QUESTIONS" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Text="{Binding TotalQuestionsText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#1D4ED8"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#93C5FD"
                            Text="AVG ACCURACY" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#60A5FA"
                            Text="{Binding AverageAccuracyText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="CORRECT / WRONG" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Text="{Binding CorrectWrongText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#92400E"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#FCD34D"
                            Text="PENDING REVIEW" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#F59E0B"
                            Text="{Binding PendingAnswersText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#166534"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#86EFAC"
                            Text="REVIEWED" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#22C55E"
                            Text="{Binding ReviewedAnswersText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="TRAINEES" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Text="{Binding TraineeCountText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="14"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="FIRST / LAST" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#F8FAFC"
                            Text="{Binding FirstLastSessionText}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="6"
            Padding="14"
            Background="#0B1117"
            BorderBrush="#33495C"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC"
                    Text="Session Report" />

                <DataGrid
                    Grid.Row="1"
                    AlternatingRowBackground="#17212B"
                    AutoGenerateColumns="False"
                    Background="#111827"
                    BorderBrush="#263746"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    ColumnHeaderHeight="38"
                    Foreground="#E5E7EB"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#263746"
                    IsReadOnly="True"
                    ItemsSource="{Binding Sessions}"
                    RowBackground="#0F1720"
                    RowHeight="36"
                    SelectionMode="Single"
                    SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="84"
                            Binding="{Binding SessionID}"
                            Header="Session" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding EmployeeNo}"
                            Header="Employee" />
                        <DataGridTextColumn
                            Width="160"
                            Binding="{Binding FullName}"
                            Header="Name" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding Department}"
                            Header="Department" />
                        <DataGridTextColumn
                            Width="165"
                            Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                            Header="Start Time" />
                        <DataGridTextColumn
                            Width="165"
                            Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                            Header="End Time" />
                        <DataGridTextColumn
                            Width="95"
                            Binding="{Binding TotalQuestions}"
                            Header="Questions" />
                        <DataGridTextColumn
                            Width="85"
                            Binding="{Binding CorrectAnswers}"
                            Header="Correct" />
                        <DataGridTextColumn
                            Width="85"
                            Binding="{Binding WrongAnswers}"
                            Header="Wrong" />
                        <DataGridTextColumn
                            Width="85"
                            Binding="{Binding PendingAnswers}"
                            Header="Pending" />
                        <DataGridTextColumn
                            Width="85"
                            Binding="{Binding ReviewedAnswers}"
                            Header="Reviewed" />
                        <DataGridTextColumn
                            Width="92"
                            Binding="{Binding Accuracy, StringFormat={}{0:0.00}%}"
                            Header="Accuracy" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Status}"
                            Header="Status" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border
            Grid.Row="8"
            Padding="16,0"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="#CBD5E1"
                Text="{Binding StatusMessage}"
                TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
