<Window
    x:Class="VisualInspectionTrainingSystem.Views.Admin.AdminWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Administration"
    Width="1380"
    Height="820"
    MinWidth="1180"
    MinHeight="720"
    Background="#0F1720"
    FontFamily="Segoe UI"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="82" />
            <RowDefinition Height="14" />
            <RowDefinition Height="96" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="88" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="22,14"
            Background="#17212B"
            BorderBrush="#2D4050"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Admin Visual Review" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="14"
                        Foreground="#9FB2C3"
                        Text="{Binding FilterSummary}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Height="46"
                    VerticalAlignment="Center"
                    Background="#1F2937"
                    BorderBrush="#4B5563"
                    BorderThickness="1"
                    Command="{Binding OpenDashboardCommand}"
                    Content="Dashboard"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />

                <Button
                    Grid.Column="3"
                    Height="46"
                    VerticalAlignment="Center"
                    Background="#2563EB"
                    BorderBrush="#60A5FA"
                    BorderThickness="1"
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />

                <Button
                    Grid.Column="5"
                    Height="46"
                    VerticalAlignment="Center"
                    Background="#7F1D1D"
                    BorderBrush="#EF4444"
                    BorderThickness="1"
                    Command="{Binding LogoutCommand}"
                    Content="Logout"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="16"
                Background="#0B1117"
                BorderBrush="#33495C"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#8EA3B5"
                        Text="TOTAL ANSWERS" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="31"
                        FontWeight="Bold"
                        Foreground="#F8FAFC"
                        Text="{Binding TotalAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Padding="16"
                Background="#0B1117"
                BorderBrush="#92400E"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#FCD34D"
                        Text="PENDING" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="31"
                        FontWeight="Bold"
                        Foreground="#F59E0B"
                        Text="{Binding PendingAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="4"
                Padding="16"
                Background="#0B1117"
                BorderBrush="#166534"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#86EFAC"
                        Text="REVIEWED" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="31"
                        FontWeight="Bold"
                        Foreground="#22C55E"
                        Text="{Binding ReviewedAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="6"
                Padding="16"
                Background="#0B1117"
                BorderBrush="#1D4ED8"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#93C5FD"
                        Text="VISIBLE" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="31"
                        FontWeight="Bold"
                        Foreground="#60A5FA"
                        Text="{Binding VisibleAnswers}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.18*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="16"
                Background="#0B1117"
                BorderBrush="#33495C"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="46" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#F8FAFC"
                            Text="{Binding SelectedImageCaption}" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#9FB2C3"
                            Text="{Binding SelectedAnswer.ImageID, StringFormat=Image {0}}" />
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Background="#030712"
                        BorderBrush="#22303C"
                        BorderThickness="1"
                        CornerRadius="3">
                        <Image
                            Margin="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{Binding SelectedImage}"
                            Stretch="Uniform" />
                    </Border>

                    <TextBlock
                        Grid.Row="2"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#8EA3B5"
                        Text="{Binding SelectedImageStatus}"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="176" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="54" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#F8FAFC"
                            Text="Selected Answer" />

                        <UniformGrid
                            Grid.Row="1"
                            Columns="3"
                            Rows="2">
                            <Border
                                Margin="0,10,8,0"
                                Padding="10"
                                Background="#111827"
                                BorderBrush="#263746"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8EA3B5"
                                        Text="EMPLOYEE NO" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        Foreground="#F8FAFC"
                                        Text="{Binding SelectedAnswer.EmployeeNo}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,10,8,0"
                                Padding="10"
                                Background="#111827"
                                BorderBrush="#263746"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8EA3B5"
                                        Text="IMAGE ID" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        Foreground="#F8FAFC"
                                        Text="{Binding SelectedAnswer.ImageID}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,10,0,0"
                                Padding="10"
                                Background="#111827"
                                BorderBrush="#263746"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8EA3B5"
                                        Text="USER ANSWER" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        Foreground="#93C5FD"
                                        Text="{Binding SelectedUserAnswerText}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,8,8,0"
                                Padding="10"
                                Background="#111827"
                                BorderBrush="#263746"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8EA3B5"
                                        Text="CORRECT ANSWER" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        Foreground="#FCD34D"
                                        Text="{Binding SelectedCorrectAnswerText}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,8,8,0"
                                Padding="10"
                                Background="#111827"
                                BorderBrush="#263746"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8EA3B5"
                                        Text="IS CORRECT" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        Foreground="#F8FAFC"
                                        Text="{Binding SelectedIsCorrectText}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,8,0,0"
                                Padding="10"
                                Background="#111827"
                                BorderBrush="#263746"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8EA3B5"
                                        Text="ANSWER TIME" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#F8FAFC"
                                        Text="{Binding SelectedAnswerTimeText}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="8"
                    Background="#17212B"
                    BorderBrush="#263746"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Background="#1F2937"
                            BorderBrush="#4B5563"
                            BorderThickness="1"
                            Command="{Binding ShowAllCommand}"
                            Content="All"
                            Cursor="Hand"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#F8FAFC" />

                        <Button
                            Grid.Column="2"
                            Background="#92400E"
                            BorderBrush="#F59E0B"
                            BorderThickness="1"
                            Command="{Binding ShowPendingCommand}"
                            Content="Pending"
                            Cursor="Hand"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#FFFFFF" />

                        <Button
                            Grid.Column="4"
                            Background="#166534"
                            BorderBrush="#22C55E"
                            BorderThickness="1"
                            Command="{Binding ShowReviewedCommand}"
                            Content="Reviewed"
                            Cursor="Hand"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#FFFFFF" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="4"
                    Padding="12"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#F8FAFC"
                            Text="Answer Queue" />

                        <DataGrid
                            Grid.Row="1"
                            AlternatingRowBackground="#17212B"
                            AutoGenerateColumns="False"
                            Background="#111827"
                            BorderBrush="#263746"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserResizeRows="False"
                            ColumnHeaderHeight="36"
                            Foreground="#E5E7EB"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            HorizontalGridLinesBrush="#263746"
                            IsReadOnly="True"
                            ItemsSource="{Binding Answers}"
                            RowBackground="#0F1720"
                            RowHeight="34"
                            SelectedItem="{Binding SelectedAnswer, Mode=TwoWay}"
                            SelectionMode="Single"
                            SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="70"
                                    Binding="{Binding AnswerID}"
                                    Header="Answer" />
                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding EmployeeNo}"
                                    Header="Employee" />
                                <DataGridTextColumn
                                    Width="72"
                                    Binding="{Binding ImageID}"
                                    Header="Image" />
                                <DataGridTextColumn
                                    Width="94"
                                    Binding="{Binding UserAnswer}"
                                    Header="User" />
                                <DataGridTextColumn
                                    Width="105"
                                    Binding="{Binding CorrectAnswer}"
                                    Header="Correct" />
                                <DataGridTextColumn
                                    Width="88"
                                    Binding="{Binding IsCorrect}"
                                    Header="Is Correct" />
                                <DataGridTextColumn
                                    Width="145"
                                    Binding="{Binding AnswerTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                    Header="Answer Time" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding ResultText}"
                                    Header="Status" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="6"
            Padding="16"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="230" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="#CBD5E1"
                    Text="{Binding StatusMessage}"
                    TextTrimming="CharacterEllipsis" />

                <Button
                    Grid.Column="1"
                    Height="58"
                    Background="#15803D"
                    BorderBrush="#22C55E"
                    BorderThickness="1"
                    Command="{Binding MarkGoodCommand}"
                    Content="Correct = GOOD"
                    Cursor="Hand"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#FFFFFF" />

                <Button
                    Grid.Column="3"
                    Height="58"
                    Background="#B91C1C"
                    BorderBrush="#EF4444"
                    BorderThickness="1"
                    Command="{Binding MarkNgCommand}"
                    Content="Correct = NG"
                    Cursor="Hand"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#FFFFFF" />
            </Grid>
        </Border>
    </Grid>
</Window>
