<Window
    x:Class="VisualInspectionTrainingSystem.Views.Admin.AdminWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Administration"
    Width="1280"
    Height="780"
    MinWidth="1100"
    MinHeight="680"
    Background="#101820"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="96" />
            <RowDefinition Height="16" />
            <RowDefinition Height="112" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="76" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,16"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Admin Review" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="15"
                        Foreground="#8EA3B5"
                        Text="Review saved quiz answers and assign the correct result." />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="180"
                    Height="48"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#2563EB"
                    BorderBrush="#60A5FA"
                    BorderThickness="1"
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#33495C"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#8EA3B5"
                        Text="TOTAL ANSWERS" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="34"
                        FontWeight="Bold"
                        Foreground="#F8FAFC"
                        Text="{Binding TotalAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#166534"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#86EFAC"
                        Text="REVIEWED" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="34"
                        FontWeight="Bold"
                        Foreground="#22C55E"
                        Text="{Binding ReviewedAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="4"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#92400E"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FCD34D"
                        Text="PENDING REVIEW" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="34"
                        FontWeight="Bold"
                        Foreground="#F59E0B"
                        Text="{Binding PendingAnswers}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="4"
            Padding="16"
            Background="#0B1117"
            BorderBrush="#33495C"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC"
                    Text="Saved Answers" />

                <DataGrid
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    Background="#111827"
                    BorderBrush="#263746"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    ColumnHeaderHeight="38"
                    Foreground="#111827"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding Answers}"
                    RowHeight="34"
                    SelectedItem="{Binding SelectedAnswer, Mode=TwoWay}"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding AnswerID}"
                            Header="Answer" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding SessionID}"
                            Header="Session" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding EmployeeNo}"
                            Header="Employee" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding ImageID}"
                            Header="Image" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding UserAnswer}"
                            Header="User Answer" />
                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding CorrectAnswer}"
                            Header="Correct Answer" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding IsCorrect}"
                            Header="Correct" />
                        <DataGridTextColumn
                            Width="180"
                            Binding="{Binding AnswerTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                            Header="Answer Time" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ResultText}"
                            Header="Status" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border
            Grid.Row="6"
            Padding="16"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="190" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="#CBD5E1"
                    Text="{Binding StatusMessage}" />

                <Button
                    Grid.Column="1"
                    Height="48"
                    Background="#15803D"
                    BorderBrush="#22C55E"
                    BorderThickness="1"
                    Command="{Binding MarkGoodCommand}"
                    Content="Correct = GOOD"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />

                <Button
                    Grid.Column="3"
                    Height="48"
                    Background="#B91C1C"
                    BorderBrush="#EF4444"
                    BorderThickness="1"
                    Command="{Binding MarkNgCommand}"
                    Content="Correct = NG"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />
            </Grid>
        </Border>
    </Grid>
</Window>
