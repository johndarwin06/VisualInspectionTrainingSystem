<Window
    x:Class="VisualInspectionTrainingSystem.Views.Dashboard.DashboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Dashboard"
    Width="1280"
    Height="760"
    MinWidth="1100"
    MinHeight="680"
    Background="#0F1720"
    FontFamily="Segoe UI"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="82" />
            <RowDefinition Height="14" />
            <RowDefinition Height="210" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="58" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="22,14"
            Background="#17212B"
            BorderBrush="#2D4050"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Training Dashboard" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="14"
                        Foreground="#9FB2C3"
                        Text="Live overview of quiz sessions, review workload, and accuracy." />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="140"
                    Height="46"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#2563EB"
                    BorderBrush="#60A5FA"
                    BorderThickness="1"
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Cursor="Hand"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="TOTAL SESSIONS" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Text="{Binding TotalSessionsText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="TOTAL ANSWERS" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Text="{Binding TotalAnswersText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#92400E"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#FCD34D"
                            Text="PENDING REVIEW" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="#F59E0B"
                            Text="{Binding PendingAnswersText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#166534"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#86EFAC"
                            Text="REVIEWED ANSWERS" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="#22C55E"
                            Text="{Binding ReviewedAnswersText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#1D4ED8"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#93C5FD"
                            Text="AVERAGE ACCURACY" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="#60A5FA"
                            Text="{Binding AverageAccuracyText}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="16"
                    Background="#0B1117"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#8EA3B5"
                                Text="TRAINEES" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="#F8FAFC"
                                Text="{Binding ActiveTraineesText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#8EA3B5"
                                Text="LATEST" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#F8FAFC"
                                Text="{Binding LatestSessionText}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="4"
            Padding="14"
            Background="#0B1117"
            BorderBrush="#33495C"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#F8FAFC"
                    Text="Recent Sessions" />

                <DataGrid
                    Grid.Row="1"
                    AlternatingRowBackground="#17212B"
                    AutoGenerateColumns="False"
                    Background="#111827"
                    BorderBrush="#263746"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    ColumnHeaderHeight="38"
                    Foreground="#E5E7EB"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#263746"
                    IsReadOnly="True"
                    ItemsSource="{Binding RecentSessions}"
                    RowBackground="#0F1720"
                    RowHeight="36"
                    SelectionMode="Single"
                    SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding SessionID}"
                            Header="Session" />
                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding EmployeeNo}"
                            Header="Employee" />
                        <DataGridTextColumn
                            Width="170"
                            Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                            Header="Start Time" />
                        <DataGridTextColumn
                            Width="170"
                            Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                            Header="End Time" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding TotalQuestions}"
                            Header="Questions" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding CorrectAnswers}"
                            Header="Correct" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding WrongAnswers}"
                            Header="Wrong" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding Accuracy, StringFormat={}{0:0.00}%}"
                            Header="Accuracy" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Status}"
                            Header="Status" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border
            Grid.Row="6"
            Padding="16,0"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="#CBD5E1"
                Text="{Binding StatusMessage}"
                TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
