<Window
    x:Class="VisualInspectionTrainingSystem.Views.Splash.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Visual Inspection Training System"
    Width="1000"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border Background="White" CornerRadius="15">

        <Grid>

            <!--  Splash Image  -->
            <Image Source="/Assets/Backgrounds/splash.png" Stretch="Fill" />

            <!--  Dark Overlay  -->
            <Border Background="#66000000" />

            <!--  Bottom Panel  -->
            <Border
                Height="120"
                VerticalAlignment="Bottom"
                Background="#DDFFFFFF">

                <Grid Margin="30">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto" />

                        <RowDefinition Height="Auto" />

                        <RowDefinition Height="Auto" />

                    </Grid.RowDefinitions>

                    <!--  Status  -->

                    <TextBlock
                        Grid.Row="0"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#0F4C81"
                        Text="{Binding StatusMessage}" />

                    <!--  Progress  -->

                    <ProgressBar
                        Grid.Row="1"
                        Height="18"
                        Margin="0,15,0,0"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding Progress}" />

                    <!--  Version  -->

                    <DockPanel Grid.Row="2" Margin="0,15,0,0">

                        <TextBlock
                            FontSize="12"
                            Foreground="Gray"
                            Text="Visual Inspection Training System" />

                        <TextBlock
                            DockPanel.Dock="Right"
                            FontSize="12"
                            Foreground="Gray"
                            Text="{Binding Version}" />

                    </DockPanel>

                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>