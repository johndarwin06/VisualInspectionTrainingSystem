<Window
    x:Class="VisualInspectionTrainingSystem.Views.Splash.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Visual Inspection Training System"
    Width="1000"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border Background="#FFFFFFFF" CornerRadius="15">

        <Grid>

            <Image Source="/Assets/Backgrounds/splash.png" Stretch="Fill" />

            <Border Background="#66000000" />

            <Border
                Height="178"
                VerticalAlignment="Bottom"
                Background="#F2FFFFFF">

                <Grid Margin="32,24,32,22">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="#0F4C81"
                        Text="{Binding StatusMessage}"
                        TextTrimming="CharacterEllipsis" />

                    <TextBlock
                        Grid.Row="1"
                        MaxHeight="44"
                        Margin="0,8,0,0"
                        FontSize="13"
                        Foreground="#40464F"
                        Text="{Binding DiagnosticMessage}"
                        TextWrapping="Wrap" />

                    <ProgressBar
                        Grid.Row="2"
                        Height="18"
                        Margin="0,16,0,0"
                        Background="#FFE6EDF3"
                        BorderBrush="#FF9BA9B5"
                        Foreground="#FF0F7B58"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding Progress}" />

                    <Grid Grid.Row="3" Margin="0,14,0,0">

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#606A73"
                            Text="Visual Inspection Training System" />

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">

                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="#606A73"
                                Text="{Binding Version}" />

                            <Button
                                Width="88"
                                Height="32"
                                Margin="22,0,0,0"
                                Background="#FF2F3A45"
                                BorderBrush="#FF2F3A45"
                                Command="{Binding ExitCommand}"
                                Content="Exit"
                                Foreground="#FFFFFFFF" />

                        </StackPanel>

                    </Grid>

                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>
