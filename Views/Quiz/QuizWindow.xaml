<Window x:Class="VisualInspectionTrainingSystem.Views.Quiz.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visual Inspection Training"
        Height="900"
        Width="1500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEF2F7">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========================================================= -->
        <!-- HEADER -->
        <!-- ========================================================= -->

        <Border
            Grid.Row="0"
            CornerRadius="12"
            Background="White"
            Padding="20">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="250"/>

                </Grid.ColumnDefinitions>

                <!-- Left -->

                <StackPanel>

                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="#1E293B"
                        Text="Visual Inspection Training"/>

                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="15"
                        Foreground="#64748B"
                        Text="{Binding CurrentUser}"/>

                </StackPanel>

                <!-- Right -->

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right">

                    <TextBlock
                        FontWeight="Bold"
                        FontSize="16"
                        HorizontalAlignment="Right"
                        Text="Progress"/>

                    <TextBlock
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="#2563EB"
                        HorizontalAlignment="Right"
                        Text="{Binding Progress}"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ========================================================= -->
        <!-- IMAGE -->
        <!-- ========================================================= -->

        <Border
            Grid.Row="2"
            Background="White"
            BorderBrush="#D1D5DB"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20">

            <Grid>

                <Image
                    Stretch="Uniform"
                    Source="{Binding CurrentImage}" />

            </Grid>

        </Border>

        <!-- ========================================================= -->
        <!-- FOOTER -->
        <!-- ========================================================= -->

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>

                <ColumnDefinition/>

                <ColumnDefinition Width="20"/>

                <ColumnDefinition/>

            </Grid.ColumnDefinitions>

            <!-- GOOD -->

            <Button
                Grid.Column="0"
                Height="70"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                Background="#16A34A"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding GoodCommand}"
                Content="GOOD (G)" />

            <!-- NG -->

            <Button
                Grid.Column="2"
                Height="70"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                Background="#DC2626"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding NgCommand}"
                Content="NG (N)" />

        </Grid>

    </Grid>

</Window>