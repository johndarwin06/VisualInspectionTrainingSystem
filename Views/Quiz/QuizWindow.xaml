<Window
    x:Class="VisualInspectionTrainingSystem.Views.Quiz.QuizWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Visual Inspection Training"
    Width="1500"
    Height="900"
    MinWidth="1200"
    MinHeight="760"
    Background="#101820"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,18"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="390" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Visual Inspection Training" />

                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="Trainee" />
                        <TextBlock
                            Margin="12,0,0,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#FFFFFF"
                            Text="{Binding CurrentUser}" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="18,10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#0E1720"
                    BorderBrush="#33495C"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel HorizontalAlignment="Right">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#8EA3B5"
                            Text="QUESTION PROGRESS" />
                        <TextBlock
                            Margin="0,2,0,0"
                            HorizontalAlignment="Right"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#38BDF8"
                            Text="{Binding QuestionProgressText}" />
                        <Grid Margin="0,4,0,0">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="13"
                                Foreground="#CBD5E1"
                                Text="{Binding AnsweredRemainingText}" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#E2E8F0"
                                Text="{Binding CompletionPercentage, StringFormat={}{0:0}%}" />
                        </Grid>
                        <ProgressBar
                            Width="350"
                            Height="8"
                            Margin="0,6,0,0"
                            Maximum="100"
                            Value="{Binding CompletionPercentage, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Padding="18"
            Background="#0B1117"
            BorderBrush="#33495C"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#CBD5E1"
                            Text="INSPECTION IMAGE" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="12"
                            Foreground="#94A3B8"
                            Text="{Binding ImageStatus}" />
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="13"
                            Foreground="#94A3B8"
                            Text="G = GOOD" />
                        <TextBlock
                            Margin="22,0,0,0"
                            FontSize="13"
                            Foreground="#94A3B8"
                            Text="N = NG" />
                        <TextBlock
                            Margin="22,0,0,0"
                            FontSize="13"
                            Foreground="#94A3B8"
                            Text="Esc = Exit" />
                    </StackPanel>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="#05080C"
                    BorderBrush="#1F2A36"
                    BorderThickness="1"
                    CornerRadius="3">
                    <Image
                        Margin="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="{Binding CurrentImage}"
                        Stretch="Uniform" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Height="130"
                Background="#15803D"
                BorderBrush="#22C55E"
                BorderThickness="2"
                Command="{Binding GoodCommand}"
                Cursor="Hand"
                Foreground="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="42"
                        FontWeight="Bold"
                        Text="GOOD" />
                    <TextBlock
                        Grid.Row="1"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Press G" />
                </Grid>
            </Button>

            <Button
                Grid.Column="2"
                Height="130"
                Background="#B91C1C"
                BorderBrush="#EF4444"
                BorderThickness="2"
                Command="{Binding NgCommand}"
                Cursor="Hand"
                Foreground="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="42"
                        FontWeight="Bold"
                        Text="NG" />
                    <TextBlock
                        Grid.Row="1"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Press N" />
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Window>
