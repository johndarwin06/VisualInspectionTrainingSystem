<Window
    x:Class="VisualInspectionTrainingSystem.Views.Result.ResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Training Result"
    Width="1280"
    Height="820"
    MinWidth="1000"
    MinHeight="650"
    Background="#101820"
    FontFamily="Segoe UI"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#0B1117" />
            <Setter Property="BorderBrush" Value="#33495C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <Style x:Key="MetricHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#94A3B8" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>

        <Style x:Key="ChartLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style x:Key="ChartBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Margin" Value="0,6,0,14" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Minimum" Value="0" />
        </Style>

        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="#263746" />
            <Setter Property="BorderBrush" Value="#4B6478" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,14"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="29"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Training Result" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="14"
                        Foreground="#8EA3B5"
                        Text="Read-only performance summary and answer analysis" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#8EA3B5"
                        Text="COMPLETED" />
                    <TextBlock
                        Margin="0,3,0,0"
                        HorizontalAlignment="Right"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="#FFFFFF"
                        Text="{Binding CompletedAtText, Mode=OneWay}" />
                    <TextBlock
                        Margin="0,3,0,0"
                        HorizontalAlignment="Right"
                        FontSize="13"
                        Foreground="#94A3B8">
                        <Run Text="Questions: " />
                        <Run Text="{Binding TotalQuestions, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl
            Grid.Row="2"
            Background="#17212B"
            BorderBrush="#33495C"
            Foreground="#111827">

            <TabItem Header="Overview">
                <ScrollViewer
                    Background="#101820"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="TOTAL QUESTIONS" />
                                    <TextBlock Style="{StaticResource MetricValue}" Text="{Binding TotalQuestions, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="Answer snapshot" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}" BorderBrush="#166534">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Foreground="#86EFAC" Text="USER GOOD" />
                                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#22C55E" Text="{Binding GoodAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="{Binding GoodPercentage, Mode=OneWay, StringFormat={}{0:0.00}% of all answers}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}" BorderBrush="#991B1B">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Foreground="#FCA5A5" Text="USER NG" />
                                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#EF4444" Text="{Binding NgAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="{Binding NgPercentage, Mode=OneWay, StringFormat={}{0:0.00}% of all answers}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}" BorderBrush="#075985">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Foreground="#7DD3FC" Text="REVIEWED ACCURACY" />
                                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#38BDF8" Text="{Binding AccuracyText, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="Reviewed answers only" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Margin="6,12,6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Padding="20"
                                Background="#0B1117"
                                BorderBrush="#33495C"
                                BorderThickness="1"
                                CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Answer Distribution" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="GOOD selections" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}">
                                            <Run Text="{Binding GoodAnswers, Mode=OneWay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding GoodPercentage, Mode=OneWay, StringFormat={}{0:0.00}%}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#22C55E"
                                        Value="{Binding GoodPercentage, Mode=OneWay}" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="NG selections" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}">
                                            <Run Text="{Binding NgAnswers, Mode=OneWay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding NgPercentage, Mode=OneWay, StringFormat={}{0:0.00}%}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#EF4444"
                                        Value="{Binding NgPercentage, Mode=OneWay}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="2"
                                Padding="20"
                                Background="#0B1117"
                                BorderBrush="#33495C"
                                BorderThickness="1"
                                CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Review Coverage and Outcomes" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="Reviewed" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}">
                                            <Run Text="{Binding ReviewedAnswers, Mode=OneWay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding ReviewCoveragePercentage, Mode=OneWay, StringFormat={}{0:0.00}%}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#38BDF8"
                                        Value="{Binding ReviewCoveragePercentage, Mode=OneWay}" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="Pending review" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}">
                                            <Run Text="{Binding PendingReviewAnswers, Mode=OneWay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding PendingReviewPercentage, Mode=OneWay, StringFormat={}{0:0.00}%}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#F59E0B"
                                        Value="{Binding PendingReviewPercentage, Mode=OneWay}" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="Correct reviewed / reviewed accuracy" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}">
                                            <Run Text="{Binding CorrectAnswers, Mode=OneWay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding AccuracyText, Mode=OneWay}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#22C55E"
                                        Value="{Binding ReviewedAccuracyPercentage, Mode=OneWay}" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="Wrong reviewed" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}">
                                            <Run Text="{Binding WrongAnswers, Mode=OneWay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding ReviewedWrongPercentage, Mode=OneWay, StringFormat={}{0:0.00}%}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#EF4444"
                                        Value="{Binding ReviewedWrongPercentage, Mode=OneWay}" />
                                    <TextBlock
                                        Foreground="#94A3B8"
                                        Text="Pending answers are not counted as wrong."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock
                            Margin="12,24,12,4"
                            Style="{StaticResource SectionTitle}"
                            Text="Timing (valid non-negative answers only)" />
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="TOTAL TIME" />
                                    <TextBlock Style="{StaticResource MetricValue}" FontSize="24" Text="{Binding TotalElapsedText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="AVERAGE TIME" />
                                    <TextBlock Style="{StaticResource MetricValue}" FontSize="24" Text="{Binding AverageElapsedText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="FASTEST TIME" />
                                    <TextBlock Style="{StaticResource MetricValue}" FontSize="24" Text="{Binding FastestElapsedText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="SLOWEST TIME" />
                                    <TextBlock Style="{StaticResource MetricValue}" FontSize="24" Text="{Binding SlowestElapsedText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Answer Review">
                <Grid Margin="16" Background="#101820">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button
                                Style="{StaticResource FilterButton}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="All"
                                Content="All Answers" />
                            <Button
                                Style="{StaticResource FilterButton}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="Wrong"
                                Content="Reviewed Wrong" />
                            <Button
                                Style="{StaticResource FilterButton}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="NG"
                                Content="User NG" />
                            <Button
                                Style="{StaticResource FilterButton}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="Pending"
                                Content="Pending Review" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontWeight="SemiBold"
                                Foreground="#F8FAFC">
                                <Run Text="Filter: " />
                                <Run Text="{Binding SelectedFilter, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Right"
                                Foreground="#94A3B8"
                                Text="{Binding FilteredAnswerCountText, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="2*" MinWidth="310" />
                        </Grid.ColumnDefinitions>

                        <DataGrid
                            Grid.Column="0"
                            AutoGenerateColumns="False"
                            AlternatingRowBackground="#E2E8F0"
                            Background="#F8FAFC"
                            BorderBrush="#33495C"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserResizeRows="False"
                            ColumnHeaderHeight="38"
                            Foreground="#111827"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding DisplayedAnswers, Mode=OneWay}"
                            RowBackground="#F8FAFC"
                            RowHeight="34"
                            SelectedItem="{Binding SelectedAnswer, Mode=TwoWay}"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="55" Binding="{Binding Sequence, Mode=OneWay}" Header="#" />
                                <DataGridTextColumn Width="2*" Binding="{Binding FileName, Mode=OneWay}" Header="Image" />
                                <DataGridTextColumn Width="85" Binding="{Binding UserAnswerText, Mode=OneWay}" Header="User" />
                                <DataGridTextColumn Width="95" Binding="{Binding CorrectAnswerText, Mode=OneWay}" Header="Truth" />
                                <DataGridTextColumn Width="125" Binding="{Binding ResultText, Mode=OneWay}" Header="Outcome" />
                                <DataGridTextColumn Width="90" Binding="{Binding ElapsedTimeText, Mode=OneWay}" Header="Elapsed" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border
                            Grid.Column="2"
                            Padding="16"
                            Background="#0B1117"
                            BorderBrush="#33495C"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitle}" Text="Selected Answer" />

                                <Border
                                    Grid.Row="2"
                                    Background="#111827"
                                    BorderBrush="#263746"
                                    BorderThickness="1">
                                    <Grid>
                                        <Image
                                            Margin="8"
                                            Source="{Binding SelectedImagePreview, Mode=OneWay}"
                                            Stretch="Uniform" />
                                        <TextBlock
                                            Margin="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom"
                                            FontSize="13"
                                            Foreground="#CBD5E1"
                                            Text="{Binding PreviewStatus, Mode=OneWay}"
                                            TextAlignment="Center"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="4">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="#F8FAFC"
                                        Text="{Binding SelectedAnswer.FileName, Mode=OneWay, TargetNullValue=No answer selected}" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Foreground="#94A3B8" Text="User answer" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="#E2E8F0"
                                                Text="{Binding SelectedAnswer.UserAnswerText, Mode=OneWay, TargetNullValue=—}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Foreground="#94A3B8" Text="Reviewed truth" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="#E2E8F0"
                                                Text="{Binding SelectedAnswer.CorrectAnswerText, Mode=OneWay, TargetNullValue=—}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Foreground="#94A3B8" Text="Outcome" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="#E2E8F0"
                                                Text="{Binding SelectedAnswer.ResultText, Mode=OneWay, TargetNullValue=—}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Foreground="#94A3B8" Text="Elapsed" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="#E2E8F0"
                                                Text="{Binding SelectedAnswer.ElapsedTimeText, Mode=OneWay, TargetNullValue=—}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="NG Analysis">
                <ScrollViewer
                    Background="#101820"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Border
                            Margin="6"
                            Padding="18"
                            Background="#17212B"
                            BorderBrush="#33495C"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock Foreground="#CBD5E1" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="#F8FAFC" Text="How to read this analysis: " />
                                <Run Text="User NG counts every trainee NG selection. Detection and false-NG metrics use reviewed administrator truth only. Pending answers are excluded from reviewed classifications and are never treated as wrong." />
                            </TextBlock>
                        </Border>

                        <UniformGrid Columns="5">
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="USER NG" />
                                    <TextBlock Style="{StaticResource MetricValue}" Text="{Binding NgAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="{Binding UserNgRatePercentage, Mode=OneWay, StringFormat={}{0:0.00}% of all}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Text="ACTUAL NG (REVIEWED)" />
                                    <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ReviewedActualNgAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="Administrator truth" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}" BorderBrush="#166534">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Foreground="#86EFAC" Text="DETECTED NG" />
                                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#22C55E" Text="{Binding CorrectlyDetectedNgAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="User NG / truth NG" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}" BorderBrush="#92400E">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Foreground="#FCD34D" Text="FALSE NG" />
                                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#F59E0B" Text="{Binding FalseNgAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="User NG / truth GOOD" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}" BorderBrush="#991B1B">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricHeader}" Foreground="#FCA5A5" Text="MISSED NG" />
                                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#EF4444" Text="{Binding MissedNgAnswers, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="User GOOD / truth NG" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Margin="6,16,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Padding="22"
                                Background="#0B1117"
                                BorderBrush="#33495C"
                                BorderThickness="1"
                                CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="NG Detection Rate" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="Correctly detected / reviewed actual NG" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}" Text="{Binding NgDetectionRateText, Mode=OneWay}" />
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#22C55E"
                                        Value="{Binding NgDetectionRatePercentage, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" TextWrapping="Wrap">
                                        <Run Text="Detected " />
                                        <Run FontWeight="SemiBold" Text="{Binding CorrectlyDetectedNgAnswers, Mode=OneWay}" />
                                        <Run Text=" of " />
                                        <Run FontWeight="SemiBold" Text="{Binding ReviewedActualNgAnswers, Mode=OneWay}" />
                                        <Run Text=" reviewed actual NG images. N/A means no reviewed actual NG denominator is available." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="2"
                                Padding="22"
                                Background="#0B1117"
                                BorderBrush="#33495C"
                                BorderThickness="1"
                                CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="False NG Rate" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource ChartLabel}" Text="False NG / reviewed actual GOOD" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ChartLabel}" Text="{Binding FalseNgRateText, Mode=OneWay}" />
                                    </Grid>
                                    <ProgressBar
                                        Style="{StaticResource ChartBar}"
                                        Foreground="#F59E0B"
                                        Value="{Binding FalseNgRatePercentage, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" TextWrapping="Wrap">
                                        <Run Text="Marked NG on " />
                                        <Run FontWeight="SemiBold" Text="{Binding FalseNgAnswers, Mode=OneWay}" />
                                        <Run Text=" of " />
                                        <Run FontWeight="SemiBold" Text="{Binding ReviewedActualGoodAnswers, Mode=OneWay}" />
                                        <Run Text=" reviewed actual GOOD images. N/A means no reviewed actual GOOD denominator is available." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
