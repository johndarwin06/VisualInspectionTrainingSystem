<Window
    x:Class="VisualInspectionTrainingSystem.Views.Result.ResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Training Result"
    Width="1180"
    Height="760"
    MinWidth="1000"
    MinHeight="650"
    Background="#101820"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="96" />
            <RowDefinition Height="16" />
            <RowDefinition Height="150" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,16"
            Background="#17212B"
            BorderBrush="#263746"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Training Result" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="15"
                        Foreground="#8EA3B5"
                        Text="Visual inspection answer summary" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#8EA3B5"
                        Text="COMPLETED" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Right"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFFFFF"
                        Text="{Binding CompletedAtText}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#33495C"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#8EA3B5"
                        Text="TOTAL QUESTIONS" />
                    <TextBlock
                        Margin="0,14,0,0"
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="#F8FAFC"
                        Text="{Binding TotalQuestions}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#166534"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#86EFAC"
                        Text="GOOD ANSWERS" />
                    <TextBlock
                        Margin="0,14,0,0"
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="#22C55E"
                        Text="{Binding GoodAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="4"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#991B1B"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FCA5A5"
                        Text="NG ANSWERS" />
                    <TextBlock
                        Margin="0,14,0,0"
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="#EF4444"
                        Text="{Binding NgAnswers}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="6"
                Padding="18"
                Background="#0B1117"
                BorderBrush="#33495C"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#8EA3B5"
                        Text="AVERAGE TIME" />
                    <TextBlock
                        Margin="0,14,0,0"
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="#38BDF8"
                        Text="{Binding AverageElapsedText}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="4"
            Padding="18"
            Background="#0B1117"
            BorderBrush="#33495C"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        Text="Answer Details" />

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="13"
                            Foreground="#94A3B8"
                            Text="Total Time:" />
                        <TextBlock
                            Margin="8,0,24,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#E2E8F0"
                            Text="{Binding TotalElapsedText}" />
                        <TextBlock
                            FontSize="13"
                            Foreground="#94A3B8"
                            Text="Review:" />
                        <TextBlock
                            Margin="8,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#E2E8F0"
                            Text="{Binding ReviewStatusText}" />
                    </StackPanel>
                </Grid>

                <DataGrid
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    Background="#111827"
                    BorderBrush="#263746"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    ColumnHeaderHeight="38"
                    Foreground="#111827"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding Answers}"
                    RowHeight="34"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding Sequence}"
                            Header="#" />
                        <DataGridTextColumn
                            Width="2*"
                            Binding="{Binding FileName}"
                            Header="Image" />
                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding UserAnswer}"
                            Header="Answer" />
                        <DataGridTextColumn
                            Width="150"
                            Binding="{Binding ElapsedSeconds, StringFormat={}{0:0.00} s}"
                            Header="Elapsed" />
                        <DataGridTextColumn
                            Width="170"
                            Binding="{Binding ResultText}"
                            Header="Review Status" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#94A3B8"
                        Text="Accuracy is available after administrator review." />

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="13"
                            Foreground="#94A3B8"
                            Text="Accuracy:" />
                        <TextBlock
                            Margin="8,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#E2E8F0"
                            Text="{Binding AccuracyText}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
